/* 全局样式 */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, "PingFang SC", "Microsoft YaHei", sans-serif;
  color: #333;
  font-size: 28rpx;
}

/* 容器 */
.container {
  padding: 24rpx;
  min-height: 100vh;
}

/* ========== 按钮 ========== */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
}
.btn::after { border: none; }

.btn-primary {
  background-color: #c0292b;
  color: #fff;
}
.btn-primary:active { background-color: #a0201e; }

.btn-default {
  background-color: #fff;
  color: #333;
  border: 1rpx solid #ddd;
}

.btn-danger {
  background-color: #fff;
  color: #c0292b;
  border: 1rpx solid #c0292b;
}

.btn-sm {
  height: 60rpx;
  font-size: 24rpx;
  padding: 0 24rpx;
  border-radius: 8rpx;
}

/* ========== 卡片 ========== */
.card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

/* ========== 表单 ========== */
.form-item {
  display: flex;
  flex-direction: column;
  margin-bottom: 28rpx;
}
.form-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}
.form-label.required::after {
  content: ' *';
  color: #c0292b;
}
.form-input {
  height: 80rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 10rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  background: #fafafa;
}
.form-input:focus {
  border-color: #c0292b;
  background: #fff;
}

/* ========== 标签 ========== */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}
.tag-paid {
  background-color: #e8f5e9;
  color: #2e7d32;
}
.tag-unpaid {
  background-color: #fce4e4;
  color: #c0292b;
}
.tag-suspended {
  background-color: #fff3e0;
  color: #e65100;
}
.tag-transferred {
  background-color: #eeeeee;
  color: #757575;
}

/* ========== 统计卡片 ========== */
.stat-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}
.stat-card {
  flex: 1;
  background: #fff;
  border-radius: 14rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}
.stat-num {
  font-size: 44rpx;
  font-weight: 700;
  color: #c0292b;
  line-height: 1.2;
}
.stat-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

/* ========== 列表项 ========== */
.list-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.list-item:last-child { border-bottom: none; }

/* ========== 空状态 ========== */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  color: #bbb;
  font-size: 26rpx;
}
.empty-icon { font-size: 80rpx; margin-bottom: 16rpx; }

/* ========== 顶部横幅 ========== */
.page-header {
  background: linear-gradient(135deg, #c0292b 0%, #922120 100%);
  padding: 40rpx 32rpx 36rpx;
  color: #fff;
  margin: -24rpx -24rpx 24rpx;
  border-radius: 0 0 20rpx 20rpx;
}
.page-header-title {
  font-size: 36rpx;
  font-weight: 700;
}
.page-header-sub {
  font-size: 24rpx;
  opacity: 0.85;
  margin-top: 6rpx;
}

/* ========== 分割线 ========== */
.divider {
  height: 1rpx;
  background-color: #f0f0f0;
  margin: 16rpx 0;
}

/* ========== 文字颜色 ========== */
.text-red   { color: #c0292b; }
.text-green { color: #27ae60; }
.text-gray  { color: #999; }
.text-bold  { font-weight: 600; }
.text-sm    { font-size: 24rpx; }
.text-lg    { font-size: 34rpx; }
