.page {
  min-height: 100vh;
  background: linear-gradient(160deg, #c0292b 0%, #7b1a1c 38%, #f5f5f5 38%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 48rpx 40rpx;
}

.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
}

.logo-img {
  width: 110rpx;
  height: 110rpx;
  margin-bottom: 20rpx;
  filter: drop-shadow(0 4rpx 12rpx rgba(0,0,0,0.25));
}

/* 与首页 .hero-title / .hero-title-line 保持一致 */
.logo-title {
  font-weight: 700;
  color: #fff;
  text-align: center;
}
.logo-title-line {
  font-size: 40rpx;
  letter-spacing: 2rpx;
  line-height: 1.4;
}
.logo-sub {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 14rpx;
  letter-spacing: 4rpx;
}

.form-card {
  width: 100%;
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.12);
}

.login-btn {
  width: 100%;
  margin-top: 16rpx;
  font-size: 32rpx;
}

.hint {
  font-size: 22rpx;
  color: #bbb;
  margin-top: 32rpx;
  text-align: center;
}
