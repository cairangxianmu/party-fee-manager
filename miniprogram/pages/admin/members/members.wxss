.toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.member-count { align-self: center; }

.member-item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.member-item:last-child { border-bottom: none; }

.member-main { flex: 1; }
.member-name { font-size: 30rpx; margin-bottom: 6rpx; }
.member-meta { margin-top: 4rpx; }
.member-status-row { display: flex; margin-top: 10rpx; flex-wrap: wrap; gap: 8rpx; }

.member-actions {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
  min-width: 100rpx;
}
.mt4 { margin-top: 4rpx; }

.picker-val { color: #333; display: flex; justify-content: space-between; align-items: center; }

/* 弹窗 */
.modal-mask {
  position: fixed; inset: 0; background: rgba(0,0,0,0.5);
  display: flex; align-items: flex-end; z-index: 100;
}
.modal-box {
  width: 100%; background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx 28rpx 48rpx;
  max-height: 90vh;
  display: flex; flex-direction: column;
}
.modal-title {
  font-size: 32rpx; font-weight: 700; color: #222;
  margin-bottom: 24rpx; text-align: center;
}
.modal-footer {
  display: flex; gap: 20rpx; margin-top: 24rpx;
}
