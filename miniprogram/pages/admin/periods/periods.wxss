.toolbar {
  display: flex; align-items: center;
  justify-content: space-between; margin-bottom: 20rpx;
}

.period-item {
  display: flex; align-items: center;
  justify-content: space-between;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.period-item:last-child { border-bottom: none; }

.period-name { font-size: 30rpx; margin-bottom: 6rpx; }
.period-date { margin-top: 4rpx; }

.tip-card {
  background: #fff8f0;
  border-left: 6rpx solid #f39c12;
  border-radius: 10rpx;
  padding: 20rpx 24rpx;
  margin-top: 24rpx;
}
.tip-title { font-size: 26rpx; font-weight: 600; color: #e67e22; margin-bottom: 10rpx; }
.tip-text { font-size: 24rpx; color: #666; line-height: 1.6; }

.modal-mask {
  position: fixed; inset: 0; background: rgba(0,0,0,0.5);
  display: flex; align-items: flex-end; z-index: 100;
}
.modal-box {
  width: 100%; background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx 28rpx 48rpx;
}
.modal-title { font-size: 32rpx; font-weight: 700; color: #222; margin-bottom: 24rpx; text-align: center; }
.modal-footer { display: flex; gap: 20rpx; margin-top: 24rpx; }

.month-grid {
  display: flex; flex-wrap: wrap; gap: 16rpx; padding: 4rpx 0;
}
.month-item {
  width: calc(25% - 13rpx);
  height: 72rpx;
  border: 2rpx solid #ddd;
  border-radius: 10rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 26rpx; color: #555; background: #f9f9f9;
}
.month-selected {
  background: #c0292b; border-color: #c0292b;
  color: #fff; font-weight: 600;
}
.preview-box {
  background: #f0f7ff; border-radius: 10rpx;
  padding: 16rpx 20rpx; margin-top: 16rpx;
}
.preview-title { font-size: 24rpx; color: #2980b9; font-weight: 600; margin-bottom: 8rpx; }
.preview-item { font-size: 24rpx; color: #555; line-height: 1.9; }
.picker-val { color: #333; }
