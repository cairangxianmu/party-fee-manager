.pay-card {
  background: #fff; border-radius: 16rpx;
  padding: 28rpx 26rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  display: flex; align-items: center; justify-content: space-between;
  border-left: 6rpx solid #c0292b;
}
.pay-info { flex: 1; margin-right: 20rpx; min-width: 0; }
.pay-period { font-size: 30rpx; margin-bottom: 10rpx; color: #222; }
.pay-amount { font-size: 24rpx; color: #888; }
.amount-num { font-size: 42rpx; font-weight: 700; color: #c0292b; margin-right: 2rpx; }

.btn-pay { width: 180rpx; height: 72rpx; font-size: 26rpx; flex-shrink: 0; }

.all-paid-card {
  background: #fff; border-radius: 20rpx;
  padding: 60rpx 32rpx;
  display: flex; flex-direction: column; align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  margin-bottom: 24rpx;
}
.all-paid-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.all-paid-title { font-size: 34rpx; font-weight: 700; color: #27ae60; }
.all-paid-sub { margin-top: 10rpx; }

.tip-card {
  background: #f0f7ff;
  border-left: 6rpx solid #3498db;
  border-radius: 10rpx;
  padding: 20rpx 24rpx;
  margin-top: 8rpx;
}
.tip-title { font-size: 26rpx; font-weight: 600; color: #2980b9; margin-bottom: 12rpx; }
.tip-text { font-size: 24rpx; color: #666; line-height: 2; }
