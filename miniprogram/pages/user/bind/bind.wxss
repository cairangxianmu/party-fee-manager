.page {
  min-height: 100vh;
  background: linear-gradient(160deg, #c0292b 0%, #7b1a1c 38%, #f5f5f5 38%);
  padding: 60rpx 32rpx 40rpx;
}

.hero {
  display: flex; flex-direction: column; align-items: center;
  padding-bottom: 40rpx;
}
.hero-emblem {
  width: 96rpx; height: 96rpx;
  margin-bottom: 18rpx;
  filter: drop-shadow(0 4rpx 12rpx rgba(0,0,0,0.25));
}
.hero-title { font-size: 36rpx; font-weight: 700; color: #fff; }
.hero-sub { font-size: 24rpx; color: rgba(255,255,255,0.8); margin-top: 8rpx; }

.form-card {
  background: #fff; border-radius: 20rpx;
  padding: 36rpx 28rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.10);
}

.tip {
  font-size: 24rpx; color: #666; line-height: 1.7;
  background: #fff8f0; border-radius: 10rpx;
  padding: 16rpx 18rpx; margin-bottom: 28rpx;
}

.openid-tip { text-align: right; margin-bottom: 8rpx; }

.bind-btn { width: 100%; margin-top: 16rpx; }

.loading-area {
  display: flex; justify-content: center; padding: 80rpx 0;
}
.loading-text { font-size: 28rpx; }

.notice {
  margin-top: 32rpx; background: rgba(255,255,255,0.9);
  border-radius: 16rpx; padding: 24rpx 28rpx;
}
.notice-title { font-size: 26rpx; font-weight: 600; color: #555; margin-bottom: 14rpx; }
.notice-item { font-size: 24rpx; color: #888; line-height: 2; }
