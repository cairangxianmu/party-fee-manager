.profile-card {
  background: linear-gradient(135deg, #c0292b 0%, #7b1a1c 100%);
  border-radius: 20rpx;
  padding: 32rpx 28rpx;
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  box-shadow: 0 6rpx 24rpx rgba(120,30,30,0.18);
}
.profile-avatar {
  width: 88rpx; height: 88rpx; border-radius: 50%;
  background: rgba(255,255,255,0.22);
  border: 2rpx solid rgba(255,255,255,0.45);
  display: flex; align-items: center; justify-content: center;
  font-size: 40rpx; font-weight: 700; color: #fff;
  margin-right: 22rpx; flex-shrink: 0;
}
.profile-info { flex: 1; min-width: 0; }
.profile-name { font-size: 32rpx; color: #fff; letter-spacing: 1rpx; }
.profile-sub { margin-top: 6rpx; color: rgba(255,255,255,0.75); }
.back-btn {
  font-size: 24rpx; color: rgba(255,255,255,0.8);
  padding: 8rpx 16rpx;
  border: 1rpx solid rgba(255,255,255,0.5);
  border-radius: 20rpx;
}

.unpaid-banner {
  background: linear-gradient(90deg, #fff3cd, #fff9e6);
  border: 1rpx solid #ffc107;
  border-radius: 14rpx;
  padding: 20rpx 24rpx;
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 24rpx;
}
.banner-left { display: flex; align-items: center; gap: 16rpx; }
.banner-icon { font-size: 40rpx; }
.banner-title { font-size: 28rpx; font-weight: 600; color: #856404; }
.banner-sub { color: #a07806; margin-top: 4rpx; }
.banner-arrow { font-size: 40rpx; color: #c0a000; }

.section-title {
  font-size: 28rpx; font-weight: 600; color: #555;
  margin-bottom: 16rpx; padding-left: 4rpx;
}

.record-card {
  background: #fff; border-radius: 16rpx;
  padding: 26rpx 26rpx;
  margin-bottom: 18rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
  border-left: 6rpx solid #c0292b;
}
.record-period { font-size: 30rpx; font-weight: 600; color: #222; margin-bottom: 14rpx; }
.record-row { display: flex; align-items: center; justify-content: space-between; }
.record-amount { font-size: 38rpx; font-weight: 700; color: #c0292b; }
.record-meta { margin-top: 14rpx; padding-top: 12rpx; border-top: 1rpx dashed #eee; }

.profile-actions {
  display: flex; flex-direction: column; align-items: flex-end;
  gap: 10rpx; flex-shrink: 0;
}
.profile-action-btn {
  font-size: 22rpx; color: #fff;
  padding: 10rpx 20rpx;
  background: rgba(255,255,255,0.18);
  border: 1rpx solid rgba(255,255,255,0.35);
  border-radius: 30rpx;
  white-space: nowrap;
}
.profile-action-btn:active { background: rgba(255,255,255,0.28); }

.modal-mask {
  position: fixed; inset: 0; background: rgba(0,0,0,0.5);
  display: flex; align-items: flex-end; z-index: 100;
}
.modal-box {
  width: 100%; background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx 28rpx 48rpx;
}
.modal-title { font-size: 32rpx; font-weight: 700; color: #222; margin-bottom: 24rpx; text-align: center; }
.modal-footer { display: flex; gap: 20rpx; margin-top: 24rpx; }

.phone-req-banner {
  border-radius: 14rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
}
.phone-req-title { font-size: 28rpx; font-weight: 600; }
.phone-req-sub { margin-top: 6rpx; }
.phone-req-pending {
  background: linear-gradient(90deg, #eaf4fb, #f5faff);
  border: 1rpx solid #5fa8d3;
  color: #1b5886;
}
.phone-req-rejected {
  background: linear-gradient(90deg, #fce8e8, #fdf0f0);
  border: 1rpx solid #e57373;
  color: #922120;
}

.form-textarea {
  width: 100%;
  min-height: 120rpx;
  padding: 16rpx;
  background: #fafafa;
  border: 1rpx solid #e0e0e0;
  border-radius: 10rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.info-picker-box {
  height: 80rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 10rpx;
  padding: 0 24rpx;
  background: #fafafa;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 28rpx;
  color: #333;
}
.picker-arrow { color: #aaa; font-size: 24rpx; }

.form-tip {
  margin-top: -8rpx;
  margin-bottom: 16rpx;
  padding-left: 4rpx;
}
