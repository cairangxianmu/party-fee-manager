.page {
  min-height: 100vh;
  background: linear-gradient(160deg, #c0292b 0%, #7b1a1c 38%, #f5f5f5 38%);
  display: flex;
  flex-direction: column;
}

.hero {
  padding: 80rpx 40rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.emblem {
  width: 110rpx;
  height: 110rpx;
  margin-bottom: 20rpx;
  filter: drop-shadow(0 4rpx 12rpx rgba(0,0,0,0.25));
}

.hero-title {
  font-weight: 700;
  color: #fff;
  text-align: center;
}
.hero-title-line {
  font-size: 40rpx;
  letter-spacing: 2rpx;
  line-height: 1.4;
}

.hero-sub {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 14rpx;
  letter-spacing: 4rpx;
}

.entry-section {
  padding: 0 32rpx;
  margin-top: 8rpx;
  flex: 1;
}

.entry-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 6rpx 24rpx rgba(120,30,30,0.12);
  transition: transform 0.15s;
}
.entry-card:active { opacity: 0.85; transform: scale(0.98); }

.entry-icon {
  width: 92rpx;
  height: 92rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 46rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}
.entry-icon-user  { background: #fce4e4; }
.entry-icon-admin { background: #e8eaf6; }

.entry-info {
  flex: 1;
}
.entry-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 8rpx;
}
.entry-desc {
  font-size: 24rpx;
  color: #999;
}

.entry-arrow {
  font-size: 40rpx;
  color: #ccc;
  margin-left: 8rpx;
}

.footer {
  text-align: center;
  font-size: 22rpx;
  color: #bbb;
  padding: 32rpx 0 40rpx;
}
